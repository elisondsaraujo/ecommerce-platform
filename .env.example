# E-Commerce Platform - Environment Variables

# ========== JWT CONFIGURATION ==========
# IMPORTANTE: Gerar uma chave secreta complexa em produção
# Usar: openssl rand -base64 32
APP_JWT_SECRET=your-super-secret-key-change-this-in-production-at-least-32-characters-long
APP_JWT_EXPIRATION=86400000
APP_JWT_REFRESH_EXPIRATION=604800000

# ========== DATABASE POSTGRESQL ==========
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ecommerce_db
DB_USER=ecommerce_user
DB_PASSWORD=ecommerce_password_change_in_production

# ========== MONGODB ==========
MONGO_URI=mongodb://ecommerce_user:ecommerce_password@mongodb:27017/ecommerce_db?authSource=admin

# ========== REDIS ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_in_production

# ========== ELASTICSEARCH ==========
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# ========== APPLICATION ==========
APP_ENV=dev
APP_PROFILE=dev
LOG_LEVEL=DEBUG
